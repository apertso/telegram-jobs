# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Токен Playwright Extension (Chrome/Edge). Берётся из самого расширения.
# Доступен ТОЛЬКО дочернему MCP-процессу, не передаётся в prompt/OpenRouter/логи/CSV.
PLAYWRIGHT_MCP_EXTENSION_TOKEN=

# Локальный порт HTTP-обработчика (Flask) и OpenRouter-модель (необязательно).
PORT=3000
OPENROUTER_MODEL=tencent/hy3:free

# Модель для браузерного агента (tool-calling). Пусто -> используется OPENROUTER_MODEL.
BROWSER_AGENT_MODEL=

# Отбрасывать сообщения старше N часов (фильтр по publishedAt).
TELEGRAM_SINCE_HOURS=24

# Необязательно: обработать только один источник из channels.json (@name или URL).
TELEGRAM_ONLY_CHANNEL=

# Таймаут ожидания загрузки канала после навигации (сек).
NAV_READY_TIMEOUT_S=5

# Параметры scroll-collect цикла (R4).
# SCROLL_MAX_ITER — макс. итераций прокрутки на фазу (к новым / к старым).
# SCROLL_WAIT_MS — пауза после прокрутки (мс) для подгрузки сообщений.
# SCROLL_TAIL_TOLERANCE_S — допуск «живого хвоста» (сек) для остановки фазы 1.
# SCROLL_STALL_LIMIT — сколько прокруток к старым подряд без прогресса считать концом истории.
SCROLL_MAX_ITER=15
SCROLL_WAIT_MS=800
SCROLL_TAIL_TOLERANCE_S=60
SCROLL_STALL_LIMIT=3

# Отдельный лимит MCP-шагов на каждый источник.
BROWSER_AGENT_MAX_STEPS=40

# Пакет Playwright MCP (валидируется перед запуском).
PLAYWRIGHT_MCP_PACKAGE=@playwright/mcp

# Подсветка перед кликом. Требует browser_highlight/browser_hide_highlight в MCP.
# Текущая версия @playwright/mcp не предоставляет эти tools — по умолчанию false
# (обычный click). Если ваша версия MCP поддерживает highlight, можно true.
HIGHLIGHT_BEFORE_CLICK=false
HIGHLIGHT_DURATION_MS=450

# Путь к CSV (необязательно).
TELEGRAM_CSV=telegram.csv

# Структурная диагностика AI и пайплайна. По умолчанию выключена.
AI_DIAGNOSTICS_ENABLED=false
